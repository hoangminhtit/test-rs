# Databricks
DATABRICKS_URL=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_HOST=
# READ — foreign catalog (dim_*, fact_* in gold)
DATABRICKS_CATALOG_NAME=ecommerce_analyst_agent_catalog
DATABRICKS_SCHEMA_NAME=gold

# WRITE — native catalog you own (NOT ecommerce_analyst_agent_catalog)
DATABRICKS_OUTPUT_CATALOG_NAME=main
DATABRICKS_OUTPUT_SCHEMA_NAME=recommender

# Gold Layer — source tables (read only)
DIM_BOOKS_TABLE=dim_books
DIM_USERS_TABLE=dim_users
DIM_DATE_TABLE=dim_date
FACT_CART_TABLE=fact_cart
# Not used in pipeline (no buyer_id in Gold schema)
FACT_REVIEWS_TABLE=fact_reviews
FACT_SALES_TABLE=fact_sales

# Pipeline output tables
BOOK_EMBEDDINGS_TABLE=book_embeddings
USER_BOOK_WEIGHTS_TABLE=user_book_weights
USER_EMBEDDINGS_TABLE=user_embeddings

# Comma-separated payment_status values counted as purchase (fact_sales)
SALES_PAYMENT_STATUSES=paid,completed,success

# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=
BOOK_COLLECTION=book_embeddings
USER_COLLECTION=user_embeddings
VECTOR_SIZE=384
QDRANT_BATCH_SIZE=1000

# FastAPI
TOP_K=20
